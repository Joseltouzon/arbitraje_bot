# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/arbitrage
REDIS_URL=redis://localhost:6379/0

# Binance API
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Operation Mode
OPERATION_MODE=detect
AUTO_TRADE=false

# Triangular Arbitrage Settings
MIN_PROFIT_THRESHOLD_PCT=0.2
START_CURRENCY=USDT
MAX_CYCLE_LENGTH=4
POLL_INTERVAL_MS=500
TRADE_AMOUNT_USDT=150

# Risk Management
MAX_TRADES_PER_HOUR=20
MAX_CONSECUTIVE_LOSSES=3
STOP_LOSS_PCT=5.0
